    "e2e": "npx ng run mi-huerto:cypress-run",
    "e2e:watch": "ng e2e",
    "prepare": "husky install"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~11.2.6",
    "@angular/cdk": "^11.2.5",
